{
  "$schema": "https://schemas.wp.org/wp/7.0/theme.json",
  "version": 3,

  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,

    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },

    "spacing": {
      "units": ["px", "rem", "%", "vw", "vh"],
      "blockGap": "2rem"
    },

    "color": {
      "palette": [
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#0B1F3A"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#87F031"
        },
        {
          "slug": "background",
          "name": "Background",
          "color": "#F7F7F5"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#111111"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#FFFFFF"
        }
      ],

      "defaultPalette": false
    },

    "typography": {
      "fluid": true,

      "fontFamilies": [
        {
          "fontFamily": "\"Inter\", sans-serif",
          "name": "Inter",
          "slug": "inter"
        },
        {
          "fontFamily": "\"Oswald\", sans-serif",
          "name": "Oswald",
          "slug": "oswald"
        }
      ],

      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.9rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.5rem"
        },
        {
          "slug": "x-large",
          "name": "XL",
          "size": "2.5rem"
        },
        {
          "slug": "xx-large",
          "name": "XXL",
          "size": "3.5rem"
        }
      ]
    }
  },

  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "1rem",
      "lineHeight": "1.7"
    },

    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--oswald)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },

      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        }
      },

      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--text)"
        },
        "border": {
          "radius": "6px"
        },
        "spacing": {
          "padding": {
            "top": "0.8rem",
            "bottom": "0.8rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "600"
        }
      }
    },

    "blocks": {
      "core/navigation": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "white"
        }
      },

      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--oswald)"
        }
      }
    }
  },

  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}